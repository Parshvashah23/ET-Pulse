# ET Pulse - Backend Environment Variables
# Copy this to .env before starting the FastAPI server

# Required - Groq LLM Inference for all AI Agents
GROQ_API_KEY=gsk_your_groq_api_key_here

# Required - Database and Auth
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJhb...your_anon_key

# Optional - URL of the Next.js frontend (used by Playwright for slide rendering)
FRONTEND_URL=http://localhost:3000
