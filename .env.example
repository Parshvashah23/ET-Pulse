# ET Pulse - Root Environment Variables Example
# Copy this file to .env and fill in the values

# --- REQUIRED API KEYS ---
# Get your free API key at https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_api_key_here

# Supabase connection (Optional for local eval, Required for prod auth/storage)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJhb...your_anon_key

# --- SERVICE URLS ---
# Where the Next.js frontend is running (Needed by backend for video slide screenshots)
FRONTEND_URL=http://localhost:3000

# Where the FastAPI backend is running
NEXT_PUBLIC_API_URL=http://localhost:8000
